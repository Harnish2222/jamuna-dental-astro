---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  ServiceHeroSection,
  ServiceStatsBar,
  ServiceTreatmentCards,
  ServiceBenefits,
  ServiceProcessTimeline,
  ServiceTestimonials,
  FloatingCTABar,
} from '@/components/service';
import WhyChooseUsSection from '@/components/WhyChooseUsSection';
import ServiceFAQ from '@/components/ServiceFAQ';
import AppointmentBookingSection from '@/components/AppointmentBookingSection';
import { Shield, Stethoscope, Heart, Clock, Search, Sparkles, Pill, Droplet } from 'lucide-react';
import { dentalImages } from '@/lib/dentalImages';
import { breadcrumbForService, medicalProcedureSchema } from '@/seo/schemas';

import jamunaDoctorOperation from '@/assets/jamuna-doctor-operation.jpg';
import jamunaTreatmentRoom from '@/assets/jamuna-treatment-room.jpg';
import jamunaClinicInterior from '@/assets/jamuna-clinic-interior.jpg';
import jamunaDoctorTreatment from '@/assets/jamuna-doctor-treatment.jpg';

const stats = [
  { value: 15000, suffix: '+', label: 'Checkups Done' },
  { value: 98, suffix: '%', label: 'Patient Satisfaction' },
  { value: 15, suffix: '+', label: 'Years Experience' },
  { value: 4.8, suffix: '★', label: 'Google Rating' },
];

const treatments = [
  { title: 'Comprehensive Dental Exam', description: 'Full oral health assessment including teeth, gums, jaw, and oral cancer screening using advanced diagnostic tools.', image: dentalImages.services.generalExam, icon: Search, duration: '30-45 min' },
  { title: 'Professional Teeth Cleaning', description: 'Deep cleaning to remove plaque, tartar, and stains, leaving your teeth sparkling clean and your gums healthy.', image: jamunaDoctorTreatment, icon: Sparkles, duration: '45-60 min' },
  { title: 'Tooth-Colored Fillings', description: 'Seamless composite fillings that blend naturally with your teeth while restoring strength and function.', image: jamunaTreatmentRoom, icon: Pill, duration: '30 min' },
  { title: 'Fluoride Treatment', description: 'Strengthen your tooth enamel and protect against decay with professional fluoride application.', image: jamunaClinicInterior, icon: Droplet, duration: '15 min' },
];

const processSteps = [
  { title: 'Warm Welcome', description: "Our friendly staff will greet you and ensure you're comfortable. We'll review your medical history and discuss any concerns.", image: jamunaClinicInterior },
  { title: 'Thorough Examination', description: 'Using advanced diagnostic tools, our dentist will examine your teeth, gums, and mouth for any issues.', image: jamunaDoctorOperation },
  { title: 'Professional Cleaning', description: 'Our hygienist will perform a deep cleaning, removing plaque and tartar buildup for optimal oral health.', image: jamunaDoctorTreatment },
  { title: 'Personalized Plan', description: "We'll discuss findings and create a treatment plan tailored to your needs and goals.", image: jamunaTreatmentRoom },
];

const benefits = [
  { icon: Shield, title: 'Preventive Care', description: 'Catch issues early, saving time and money on complex treatments' },
  { icon: Stethoscope, title: 'Expert Diagnosis', description: 'Advanced technology for accurate detection and treatment' },
  { icon: Heart, title: 'Gentle Approach', description: 'Patient-centered care with focus on your comfort' },
  { icon: Clock, title: 'Convenient Hours', description: 'Flexible scheduling including evening appointments' },
];

const testimonials = [
  { name: 'Priya Sharma', quote: 'Best dental checkup experience! The team made me feel completely at ease. My teeth have never been cleaner.', rating: 5, service: 'General Checkup' },
  { name: 'Rajesh Kumar', quote: 'I was nervous about visiting the dentist, but the gentle approach here changed everything. Highly recommend!', rating: 5, service: 'Teeth Cleaning' },
  { name: 'Anitha Venkatesh', quote: 'Excellent preventive care. They caught a small cavity early and fixed it painlessly. Great experience overall.', rating: 5, service: 'Cavity Treatment' },
];

const faqs = [
  { question: 'How often should I visit the dentist for a checkup?', answer: "We recommend visiting every 6 months for routine cleanings and checkups. However, some patients with specific conditions may need more frequent visits. During your visit, we'll advise on the best schedule for your individual needs." },
  { question: 'What happens during a dental examination?', answer: "A comprehensive dental exam includes checking your teeth for cavities, examining your gums for disease, oral cancer screening, digital X-rays if needed, and a thorough cleaning by our hygienist. We'll also discuss any concerns you have about your oral health." },
  { question: 'Are tooth-colored fillings as durable as silver fillings?', answer: 'Yes! Modern composite (tooth-colored) fillings are very durable and bond directly to your tooth, often requiring less drilling. They look natural and can last 10-15 years with proper care.' },
  { question: 'Do dental cleanings hurt?', answer: 'Professional cleanings are generally painless. If you have sensitive teeth or gum issues, let us know and we can take extra care. We also offer numbing gel if needed to ensure your comfort.' },
  { question: 'What can I do between visits to maintain good oral health?', answer: 'Brush twice daily with fluoride toothpaste, floss daily, limit sugary foods and drinks, avoid tobacco, and stay hydrated. These simple habits go a long way in preventing dental problems.' },
];
---

<BaseLayout
  title="General Dentistry in Dindigul | Checkups, Cleaning & Fillings | JFDC"
  description="General & preventive dentistry in Dindigul — oral checkups, scaling, digital X-rays, fillings & gum care by MDS specialists at Jamuna Family Dental Care. Call +91 7200 620 011."
  canonical="https://jamunadental.com/services/general-dentistry/"
  jsonLd={[
    breadcrumbForService('General Dentistry', '/services/general-dentistry/'),
    medicalProcedureSchema(
      'General & Preventive Dentistry',
      'Routine dental checkups, professional teeth cleaning, digital X-rays, fillings and gum care for all ages.',
      '/services/general-dentistry/',
    ),
  ]}
>
  <ServiceHeroSection
    badge="General Dentistry"
    title="Comprehensive Care for Your Whole Family"
    description="From routine cleanings to preventive treatments, our general dentistry services keep your smile healthy for life. We use the latest technology for comfortable, effective care at Jamuna Family Dental Care."
    backgroundImage={jamunaDoctorOperation.src}
  />

  {/* Stats counters animate when in-view; hydrate so the count-up runs. */}
  <ServiceStatsBar stats={stats} client:visible />

  <ServiceTreatmentCards
    title="Our General Dentistry Services"
    subtitle="Everything you need to maintain optimal oral health for you and your family."
    treatments={treatments}
  />

  <ServiceProcessTimeline
    title="What to Expect at Your Visit"
    subtitle="We make every visit comfortable and thorough, ensuring you leave with a healthier smile."
    steps={processSteps}
  />

  <ServiceBenefits
    badge="Why Regular Checkups Matter"
    title="Prevention is Better Than Cure"
    description="Regular dental visits are the cornerstone of good oral health. At JFDC, we focus on preventing problems before they start, saving you from pain, complex treatments, and higher costs down the line."
    benefits={benefits}
    images={[jamunaTreatmentRoom.src, jamunaClinicInterior.src]}
  />

  <ServiceTestimonials testimonials={testimonials} />

  <WhyChooseUsSection />

  <ServiceFAQ faqs={faqs} image={dentalImages.services.generalExam} />

  {/* Form state — hydrated island */}
  <AppointmentBookingSection client:load />

  <FloatingCTABar />
</BaseLayout>
