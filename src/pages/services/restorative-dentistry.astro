---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  ServiceHeroSection,
  ServiceStatsBar,
  ServiceTreatmentCards,
  ServiceBenefits,
  ServiceProcessTimeline,
  ServiceTestimonials,
  FloatingCTABar,
} from '@/components/service';
import WhyChooseUsSection from '@/components/WhyChooseUsSection';
import ServiceFAQ from '@/components/ServiceFAQ';
import AppointmentBookingSection from '@/components/AppointmentBookingSection';
import { dentalImages } from '@/lib/dentalImages';
import { Wrench, Shield, Timer, ThumbsUp, Crown, Puzzle, Circle, Bone } from 'lucide-react';
import { breadcrumbForService, medicalProcedureSchema } from '@/seo/schemas';

import jamunaDoctorOperation from '@/assets/jamuna-doctor-operation.jpg';
import jamunaTreatmentRoom from '@/assets/jamuna-treatment-room.jpg';
import jamunaClinicInterior from '@/assets/jamuna-clinic-interior.jpg';
import jamunaDoctorTreatment from '@/assets/jamuna-doctor-treatment.jpg';

const stats = [
  { value: 3000, suffix: '+', label: 'Implants Placed' },
  { value: 99, suffix: '%', label: 'Success Rate' },
  { value: 15, suffix: '+', label: 'Years Experience' },
  { value: 4.8, suffix: '★', label: 'Google Rating' },
];

const treatments = [
  { title: 'Dental Implants', description: 'Permanent replacement for missing teeth that look, feel, and function like natural teeth. Designed to last a lifetime.', image: dentalImages.services.implants, icon: Circle, duration: '3-6 months' },
  { title: 'Dental Crowns', description: 'Custom-made caps that restore damaged teeth to their original shape, size, and strength while looking natural.', image: dentalImages.services.crowns, icon: Crown, duration: '2 visits' },
  { title: 'Root Canal Therapy', description: 'Save your natural tooth and eliminate pain with our gentle, modern root canal treatment using advanced techniques.', image: jamunaDoctorOperation, icon: Puzzle, duration: '1-2 visits' },
  { title: 'Dental Bridges', description: 'Replace one or more missing teeth with a natural-looking bridge anchored to adjacent teeth or implants.', image: jamunaDoctorTreatment, icon: Bone, duration: '2-3 visits' },
];

const processSteps = [
  { title: 'Initial Consultation', description: 'We assess your condition, take detailed images, and discuss the best restoration options for you.', image: jamunaClinicInterior },
  { title: 'Treatment Planning', description: 'Our team creates a comprehensive plan, including timeline, costs, and expected outcomes.', image: jamunaTreatmentRoom },
  { title: 'Restoration Procedure', description: 'Expert treatment using advanced technology and materials for optimal results.', image: jamunaDoctorOperation },
  { title: 'Follow-Up Care', description: 'Regular check-ups to ensure your restoration is functioning perfectly and lasting long.', image: jamunaDoctorTreatment },
];

const benefits = [
  { icon: Wrench, title: 'Restore Function', description: 'Eat, speak, and smile with confidence again' },
  { icon: Shield, title: 'Prevent Damage', description: 'Stop decay and protect remaining teeth' },
  { icon: Timer, title: 'Long-Lasting', description: 'Durable solutions designed to last years' },
  { icon: ThumbsUp, title: 'Natural Look', description: 'Restorations that match your natural teeth' },
];

const testimonials = [
  { name: 'Suresh Iyer', quote: "After losing a tooth, I thought I'd never smile confidently again. The dental implant is perfect—no one can tell it's not my real tooth!", rating: 5, service: 'Dental Implant' },
  { name: 'Kavitha Mohan', quote: 'My root canal was completely painless! The team was so gentle and professional. I was amazed at how easy it was.', rating: 5, service: 'Root Canal' },
  { name: 'Ravi Chandran', quote: 'The crown they made looks so natural. It fits perfectly and I can chew normally again. Excellent work!', rating: 5, service: 'Dental Crown' },
];

const faqs = [
  { question: 'How long do dental implants last?', answer: 'With proper care and maintenance, dental implants can last a lifetime. The crown on top may need replacement after 10-15 years due to normal wear, but the implant itself (the titanium post) integrates with your bone permanently.' },
  { question: 'Is root canal treatment painful?', answer: 'Modern root canal treatment is virtually painless thanks to advanced anesthesia and techniques. Most patients report it feels similar to getting a filling. The procedure actually relieves the pain caused by infection or inflammation.' },
  { question: 'How long does it take to get dental implants?', answer: 'The complete implant process typically takes 3-6 months. This includes initial placement, healing time for bone integration, and placing the final crown. Some cases may qualify for same-day implants with immediate loading.' },
  { question: "What's the difference between a crown and a veneer?", answer: 'A crown covers the entire tooth and is used for damaged or weakened teeth, providing both cosmetic improvement and structural support. A veneer only covers the front surface and is primarily for cosmetic purposes on healthy teeth.' },
  { question: 'Can dentures look natural?', answer: 'Absolutely! Modern dentures are custom-made to match your facial features, gum color, and desired tooth appearance. They look very natural and are far more comfortable than dentures of the past.' },
];
---

<BaseLayout
  title="Dental Implants & Root Canal in Dindigul | Restorative Dentistry | JFDC"
  description="Restorative dentistry in Dindigul — dental implants, root canal treatment, crowns, bridges and dentures by MDS specialists at Jamuna Family Dental Care. Call +91 7200 620 011."
  canonical="https://jamunadental.com/services/restorative-dentistry/"
  jsonLd={[
    breadcrumbForService('Restorative Dentistry', '/services/restorative-dentistry/'),
    medicalProcedureSchema(
      'Restorative Dentistry',
      'Dental implants, root canal treatment, crowns, bridges and dentures to restore function and aesthetics.',
      '/services/restorative-dentistry/',
    ),
  ]}
>
  <ServiceHeroSection
    badge="Restorative Dentistry"
    title="Restore Your Smile's Function & Beauty"
    description="From dental implants to crowns and bridges, our restorative treatments repair damaged teeth and replace missing ones. At JFDC, we give you back your confident, fully functional smile."
    backgroundImage={dentalImages.services.implants}
  />

  <ServiceStatsBar stats={stats} client:visible />

  <ServiceTreatmentCards
    title="Restorative Treatments We Offer"
    subtitle="Advanced solutions to repair and replace damaged or missing teeth."
    treatments={treatments}
  />

  <ServiceProcessTimeline
    title="Your Restoration Journey"
    subtitle="A step-by-step process to restore your smile to full function and beauty."
    steps={processSteps}
  />

  <ServiceBenefits
    badge="Benefits"
    title="Why Restore Your Smile?"
    description="Missing or damaged teeth affect more than your appearance—they impact your ability to eat, speak, and your overall oral health. Restorative dentistry addresses these issues comprehensively."
    benefits={benefits}
    images={[jamunaTreatmentRoom.src, jamunaClinicInterior.src]}
  />

  <ServiceTestimonials testimonials={testimonials} />

  <WhyChooseUsSection />

  <ServiceFAQ faqs={faqs} image={dentalImages.services.implants} />

  <AppointmentBookingSection client:load />

  <FloatingCTABar />
</BaseLayout>
