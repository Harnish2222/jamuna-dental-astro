---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadHomepageContent } from '@/lib/load-homepage';
import { getImage } from 'astro:assets';

// Components
import WhyChooseUsSection from '@/components/WhyChooseUsSection';
import PriceTellerSection from '@/components/PriceTellerSection';
import SmileGallerySection from '@/components/SmileGallerySection';
import TestimonialsSection from '@/components/TestimonialsSection';
import AppointmentBookingSection from '@/components/AppointmentBookingSection';
import MilestonesSection from '@/components/MilestonesSection';
import AnimatedSection from '@/components/AnimatedSection';
import FAQAccordionReact from '@/components/FAQAccordionReact';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const homepageContent = await loadHomepageContent();
const allUploads = import.meta.glob('../assets/uploads/**/*.{png,jpg,jpeg,webp}', { eager: true });

async function resolveOptimizedImage(src: string | null | undefined, width: number, height: number, quality: number = 80) {
  if (!src) return null;
  const decodedSrc = decodeURIComponent(src);
  const filename = decodedSrc.split('/').pop();
  if (!filename) return src;
  const keys = Object.keys(allUploads);
  const matchedKey = keys.find(key => key.endsWith(filename));
  if (!matchedKey) return src;
  const imageModule: any = allUploads[matchedKey];
  const optimized = await getImage({
    src: imageModule.default,
    width,
    height,
    format: 'webp',
    quality
  });
  return optimized.src;
}

const heroDesktop = await resolveOptimizedImage(entry.data.heroImage, 1200, 800, 90);
const whyChooseDesktop = await resolveOptimizedImage(homepageContent?.why_choose?.image, 800, 600, 80);
const optimizedWhyChoose = { image: whyChooseDesktop };

const optimizedTransformations = await Promise.all(
  (homepageContent?.smile_gallery?.transformations || []).map(async (item: any) => {
    const desktopSrc = await resolveOptimizedImage(item.image, 600, 600, 75);
    return { ...item, image: desktopSrc };
  })
);

const optimizedTreatments = await Promise.all((homepageContent?.price_teller?.treatments || []).map(async (t: any) => {
  const desktopSrc = await resolveOptimizedImage(t.image, 800, 600, 75);
  return { ...t, image: desktopSrc };
}));

const relevantTreatment = optimizedTreatments.find(t => 
  entry.data.title.toLowerCase().includes(t.label.toLowerCase()) || 
  t.label.toLowerCase().includes(entry.data.title.toLowerCase())
);

const priceTellerContent = {
  ...homepageContent?.price_teller,
  treatments: relevantTreatment ? [relevantTreatment] : optimizedTreatments.slice(0, 3)
};
---

<BaseLayout
  title={entry.data.seoTitle}
  description={entry.data.seoDescription}
  canonical={`https://jamunadental.com/services/${entry.slug}/`}
>
  <style slot="head">
    .glass-card {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .service-hero-gradient {
      background: radial-gradient(circle at 0% 0%, rgba(7, 38, 116, 0.05) 0%, transparent 50%),
                  radial-gradient(circle at 100% 100%, rgba(0, 128, 181, 0.05) 0%, transparent 50%);
    }
    .prose h3 {
      font-size: 1.5rem;
      color: #072674;
      font-weight: 800;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .prose h3::before {
      content: "";
      width: 4px;
      height: 1.5rem;
      background: #0080B5;
      border-radius: 99px;
    }
    .prose ul {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1rem;
      list-style: none;
      padding: 0;
    }
    .prose li {
      background: #f8fafc;
      padding: 1.5rem;
      border-radius: 1rem;
      border: 1px solid #e2e8f0;
      margin-bottom: 0 !important;
      font-weight: 500;
      color: #334155;
      transition: all 0.3s ease;
    }
    .prose li:hover {
      border-color: #0080B5;
      background: white;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      transform: translateY(-2px);
    }
    .prose strong {
      color: #072674;
      font-weight: 700;
    }
    .prose p {
      color: #64748b;
      line-height: 1.8;
      font-size: 1.125rem;
    }
  </style>

  <div class="service-hero-gradient">
    {/* ─── Hero Section ────────────────────────────────────────────── */}
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          <div class="w-full lg:w-1/2 relative z-10">
            <AnimatedSection animation="fade-right">
              <span class="inline-flex items-center px-4 py-1.5 mb-6 rounded-full text-sm font-bold bg-primary/10 text-primary uppercase tracking-widest border border-primary/20">
                Premium Dental Care
              </span>
              <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.1] mb-8 tracking-tighter text-gray-900">
                {entry.data.title.split(' ').slice(0, -2).join(' ')} 
                <span class="text-primary block mt-2">{entry.data.title.split(' ').slice(-2).join(' ')}</span>
              </h1>
              <p class="text-xl text-slate-500 mb-10 leading-relaxed max-w-xl font-medium">
                {entry.data.summary}
              </p>
              <div class="flex flex-col sm:flex-row gap-5">
                <a href="#appointment" class="bg-primary hover:bg-primary/90 text-white px-10 py-5 rounded-full font-bold shadow-2xl shadow-primary/40 transition-all hover:-translate-y-1 text-center">
                  Book Free Consultation
                </a>
                <a href="tel:+917200620011" class="glass-card text-primary px-10 py-5 rounded-full font-bold transition-all flex items-center justify-center gap-3 hover:bg-white">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.03 21c.76 0 .98-.66.98-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
                  +91 7200 620 011
                </a>
              </div>
            </AnimatedSection>
          </div>
          <div class="w-full lg:w-1/2 relative">
            <AnimatedSection animation="fade-left">
              <div class="relative">
                <div class="absolute -inset-4 bg-primary/20 rounded-[3rem] blur-3xl opacity-30 animate-pulse"></div>
                <div class="relative aspect-[5/4] rounded-[3rem] overflow-hidden shadow-[0_20px_50px_rgba(8,112,184,0.3)] border-[12px] border-white z-10">
                  <img 
                    src={heroDesktop || entry.data.heroImage} 
                    alt={entry.data.title} 
                    class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-1000"
                  />
                </div>
                <div class="absolute -bottom-10 -right-10 glass-card p-8 rounded-3xl shadow-2xl z-20 border border-white/50 hidden md:block">
                  <div class="flex items-center gap-6">
                    <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-lg">
                      <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <div>
                      <div class="text-xl font-black text-gray-900">Expert Care</div>
                      <div class="text-sm font-semibold text-blue-600 uppercase tracking-widest">MDS Specialists</div>
                    </div>
                  </div>
                </div>
              </div>
            </AnimatedSection>
          </div>
        </div>
      </div>
    </section>

    {/* ─── Highlights Bar ─────────────────────────────────────────── */}
    <div class="container mx-auto px-4 -mt-10 relative z-30">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
        {[
          { label: "Modern Tech", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { label: "Pain-Free", icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" },
          { label: "Expert MDS", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
          { label: "4.9★ Rating", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.921-.755 1.688-1.54 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.784.57-1.838-.197-1.539-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" }
        ].map((item, i) => (
          <AnimatedSection animation="fade-up" delay={`delay-${i * 100}`}>
            <div class="glass-card p-6 rounded-2xl flex items-center gap-4 border border-white/40 shadow-xl">
              <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d={item.icon}/></svg>
              </div>
              <span class="font-bold text-gray-800 text-sm md:text-base leading-tight">{item.label}</span>
            </div>
          </AnimatedSection>
        ))}
      </div>
    </div>
  </div>

  {/* ─── Main Narrative Content ────────────────────────────────────── */}
  <section class="py-32 bg-white relative">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <AnimatedSection animation="fade-up">
          <div class="prose prose-slate lg:prose-xl max-w-none">
            <Content />
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>

  {/* ─── Premium Repeatable Sections ──────────────────────────────── */}
  
  <MilestonesSection client:visible content={homepageContent?.milestones as any} />

  <div class="bg-slate-50">
    <WhyChooseUsSection content={{ ...homepageContent?.why_choose, ...optimizedWhyChoose } as any} />
  </div>

  <SmileGallerySection 
    client:visible 
    content={{
      ...homepageContent?.smile_gallery,
      transformations: optimizedTransformations
    } as any} 
  />

  <PriceTellerSection 
    client:visible 
    content={priceTellerContent as any} 
  />

  <div class="py-32 bg-white">
    <TestimonialsSection client:visible content={homepageContent?.testimonials as any} />
  </div>

  <div id="appointment" class="relative z-10">
    <AppointmentBookingSection client:visible content={homepageContent?.appointment as any} />
  </div>

  <section id="faq" class="py-32 bg-slate-900 text-white overflow-hidden relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/20 rounded-full blur-[120px] -mr-48 -mt-48"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="flex flex-col lg:flex-row gap-16 items-center">
        <div class="w-full lg:w-1/3">
          <span class="text-primary font-bold tracking-[.3em] uppercase text-sm mb-6 block">Support</span>
          <h2 class="text-4xl md:text-5xl font-black mb-8 leading-tight">
            Frequently Asked <span class="text-primary">Questions</span>
          </h2>
          <p class="text-slate-400 text-lg mb-10">
            Everything you need to know about our {entry.data.title.toLowerCase()} procedures.
          </p>
          <a href="#appointment" class="inline-flex items-center gap-2 text-primary font-bold hover:gap-4 transition-all">
            Ask your own question <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="w-full lg:w-2/3 glass-card bg-white/5 rounded-3xl p-8 md:p-12 border-white/10">
          <FAQAccordionReact client:visible faqs={homepageContent?.faq?.items?.slice(0, 5) as any} />
        </div>
      </div>
    </div>
  </section>

  {/* ─── Sticky Mobile CTA ─────────────────────────────────────────── */}
  <div class="lg:hidden fixed bottom-6 left-6 right-6 z-[100] flex gap-3 pointer-events-none">
    <a href="tel:+917200620011" class="flex-1 bg-slate-900 text-white py-4 rounded-2xl font-bold shadow-2xl flex items-center justify-center gap-2 pointer-events-auto border border-white/10 backdrop-blur-lg">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.03 21c.76 0 .98-.66.98-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
      Call
    </a>
    <a href="#appointment" class="flex-[2] bg-primary text-white py-4 rounded-2xl font-bold shadow-2xl flex items-center justify-center gap-2 pointer-events-auto shadow-primary/40">
      Book Appointment
    </a>
  </div>
</BaseLayout>
