---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Screen from '@/screens/LandingPage.tsx';
import { loadLandingContent } from '@/lib/load-landing';
import { getImage } from 'astro:assets';
import jfdcLogoSrc from '@/assets/jfdc-logo.png';

const data: any = await loadLandingContent();

if (!data) {
  throw new Error("Failed to load landing page content");
}

// Resolve all images in src/assets/uploads for Astro optimization
const allUploads = import.meta.glob('../assets/uploads/**/*.{png,jpg,jpeg,webp}', { eager: true });

async function resolveOptimizedImage(src: string, width: number, height: number, quality: number = 80) {
  if (!src) return null;
  const decodedSrc = decodeURIComponent(src);
  const filename = decodedSrc.split('/').pop();
  if (!filename) return src;

  // Try to find the image in the glob by matching the end of the key
  const keys = Object.keys(allUploads);
  const matchedKey = keys.find(key => key.endsWith(filename));
  
  if (!matchedKey) {
    if (import.meta.env.DEV) {
      console.warn(`Could not find image: ${src}. Available keys:`, keys.slice(0, 10));
    }
    return src;
  }

  const imageModule: any = allUploads[matchedKey];
  
  const optimized = await getImage({
    src: imageModule.default,
    width,
    height,
    format: 'webp',
    quality
  });
  return optimized.src;
}

// Optimize Hero Carousel images
const optimizedHeroImages = await Promise.all(
  (data.hero_carousel?.images || []).map(async (img: any) => {
    const desktopSrc = await resolveOptimizedImage(img.src, 1000, 625, 75);
    const mobileSrc = await resolveOptimizedImage(img.src, 600, 450, 50);
    const smallMobileSrc = await resolveOptimizedImage(img.src, 360, 270, 45);
    return { ...img, src: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Optimize Service card images
const optimizedServices = await Promise.all(
  (data.services?.cards || []).map(async (card: any) => {
    const desktopSrc = await resolveOptimizedImage(card.image, 600, 450, 75);
    const mobileSrc = await resolveOptimizedImage(card.image, 400, 300, 50);
    const smallMobileSrc = await resolveOptimizedImage(card.image, 300, 225, 45);
    return { ...card, image: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Optimize Smile Gallery transformations
const optimizedTransformations = await Promise.all(
  (data.smile_gallery?.transformations || []).map(async (item: any) => {
    const desktopSrc = await resolveOptimizedImage(item.image, 600, 600, 75);
    const mobileSrc = await resolveOptimizedImage(item.image, 450, 450, 60);
    const smallMobileSrc = await resolveOptimizedImage(item.image, 320, 320, 55);
    
    return { 
      ...item, 
      image: desktopSrc, 
      mobileSrc, 
      smallMobileSrc
    };
  })
);

// Optimize other images
const aboutDesktop = await resolveOptimizedImage(data.about?.image, 1000, 1200, 80);
const aboutMobile = await resolveOptimizedImage(data.about?.image, 600, 720, 50);
const aboutSmallMobile = await resolveOptimizedImage(data.about?.image, 380, 456, 45);
const optimizedAbout = { image: aboutDesktop, mobileSrc: aboutMobile, smallMobileSrc: aboutSmallMobile };
const optimizedFaqImage = await resolveOptimizedImage(data.faq?.image, 1000, 750, 80);

// Optimize Gallery images
const optimizedClinicImages = await Promise.all(
  (data.clinic_gallery?.images || []).map(async (img: any) => {
    const optimizedSrc = await resolveOptimizedImage(img.src, 1200, 1200, 90);
    return { ...img, src: optimizedSrc };
  })
);

const optimizedPhotoImages = await Promise.all(
  (data.photo_gallery?.images || []).map(async (img: any) => {
    const optimizedSrc = await resolveOptimizedImage(img.src, 1000, 1000, 85);
    return { ...img, src: optimizedSrc };
  })
);

const optimizedTreatments = await Promise.all((data?.price_teller?.treatments || []).map(async (t: any) => {
  const optimizedSrc = await resolveOptimizedImage(t.image, 800, 600, 75);
  return { ...t, image: optimizedSrc };
}));

const optimizedData = {
  ...data,
  hero_carousel: { ...data.hero_carousel, images: optimizedHeroImages },
  services: { ...data.services, cards: optimizedServices },
  about: { ...data.about, ...optimizedAbout },
  smile_gallery: { ...data.smile_gallery, transformations: optimizedTransformations },
  clinic_gallery: { ...data.clinic_gallery, images: optimizedClinicImages },
  photo_gallery: { ...data.photo_gallery, images: optimizedPhotoImages },
  price_teller: { ...data.price_teller, treatments: optimizedTreatments },
  faq: { ...data.faq, image: optimizedFaqImage }
};

// Optimize logo (140x140 for retina @ 70px display)
const optimizedLogo = await getImage({
  src: jfdcLogoSrc,
  width: 140,
  height: 140,
  format: 'webp',
  quality: 90
});
---

<BaseLayout
  title={data.seo?.title || "Jamuna Family Dental Care | Trusted Family Dental Clinic in Dindigul"}
  description={data.seo?.description || "Expert MDS specialist dental care in Dindigul — implants, root canal, braces, kids dentistry. 4.9★ rated. Call +91 7200 620 011."}
  canonical={data.seo?.canonical || "https://jamunadental.com/dental"}
  noindex={data.seo?.noindex}
  hideFooterMap
  hideNav
>
  <style slot="head">
    /* Critical CSS for LCP improvement */
    #hero { min-height: 100vh; display: flex; align-items: center; }
    .hero-heading { font-size: 2.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 0.75rem; }
    @media (min-width: 1024px) { .hero-heading { font-size: 4rem; } }
    .hero-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; font-weight: 700; }
  </style>
  
  {optimizedHeroImages[0] && (
    <link 
      rel="preload" 
      as="image" 
      href={optimizedHeroImages[0].src} 
      imagesrcset={`${optimizedHeroImages[0].smallMobileSrc} 380w, ${optimizedHeroImages[0].mobileSrc} 600w, ${optimizedHeroImages[0].src} 1000w`}
      imagesizes="(max-width: 480px) 380px, (max-width: 768px) 600px, 1000px"
      slot="head"
      fetchpriority="high"
    />
  )}

  <Screen data={optimizedData} logo={optimizedLogo.src} client:load />
</BaseLayout>
