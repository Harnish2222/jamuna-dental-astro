---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Screen from '@/screens/LandingPage.tsx';
import { loadLandingContent } from '@/lib/load-landing';
import { getImage } from 'astro:assets';

const data = await loadLandingContent();

if (!data) {
  throw new Error("Failed to load landing page content");
}

// Resolve all images in src/assets/uploads for Astro optimization
const allUploads = import.meta.glob('/src/assets/uploads/**/*.{png,jpg,jpeg,webp}', { eager: true });

async function resolveOptimizedImage(src: string, width: number, height: number, quality: number = 80) {
  if (!src) return null;
  const decodedSrc = decodeURIComponent(src);
  const assetPath = decodedSrc.startsWith('/uploads/') ? `/src/assets${decodedSrc}` : `/src/assets/uploads${decodedSrc.startsWith('/') ? '' : '/'}${decodedSrc}`;
  const imageModule: any = allUploads[assetPath];
  if (!imageModule) return src;
  
  const optimized = await getImage({
    src: imageModule.default,
    width,
    height,
    format: 'webp',
    quality
  });
  return optimized.src;
}

// Optimize Hero Carousel images
const optimizedHeroImages = await Promise.all(
  (data.hero_carousel?.images || []).map(async (img: any) => {
    const desktopSrc = await resolveOptimizedImage(img.src, 1400, 875, 80);
    const mobileSrc = await resolveOptimizedImage(img.src, 600, 450, 75);
    return { ...img, src: desktopSrc, mobileSrc };
  })
);

// Optimize Service card images
const optimizedServices = await Promise.all(
  (data.services?.cards || []).map(async (card: any) => {
    const optimizedSrc = await resolveOptimizedImage(card.image, 800, 600, 75);
    return { ...card, image: optimizedSrc };
  })
);

// Optimize other images
const optimizedAboutImage = await resolveOptimizedImage(data.about?.image, 1000, 1200, 80);
const optimizedFaqImage = await resolveOptimizedImage(data.faq?.image, 1000, 750, 80);

// Optimize Gallery images
const optimizedClinicImages = await Promise.all(
  (data.clinic_gallery?.images || []).map(async (img: any) => {
    const optimizedSrc = await resolveOptimizedImage(img.src, 800, 600, 75);
    return { ...img, src: optimizedSrc };
  })
);

const optimizedPhotoImages = await Promise.all(
  (data.photo_gallery?.images || []).map(async (img: any) => {
    const optimizedSrc = await resolveOptimizedImage(img.src, 600, 600, 75);
    return { ...img, src: optimizedSrc };
  })
);

const optimizedData = {
  ...data,
  hero_carousel: { ...data.hero_carousel, images: optimizedHeroImages },
  services: { ...data.services, cards: optimizedServices },
  about: { ...data.about, image: optimizedAboutImage },
  clinic_gallery: { ...data.clinic_gallery, images: optimizedClinicImages },
  photo_gallery: { ...data.photo_gallery, images: optimizedPhotoImages },
  faq: { ...data.faq, image: optimizedFaqImage }
};
---

<BaseLayout
  title={data.seo?.title || "Trusted Family Dental Clinic in Dindigul | Jamuna Family Dental Care"}
  description={data.seo?.description || "Expert MDS specialist dental care in Dindigul — implants, root canal, braces, kids dentistry. 4.9★ rated. Call +91 7200 620 011."}
  canonical={data.seo?.canonical || "https://jamunadental.com/dental"}
  noindex={data.seo?.noindex}
  hideFooterMap
  hideNav
>
  <Screen data={optimizedData} client:load />
</BaseLayout>
