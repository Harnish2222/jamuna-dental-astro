---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Screen from '@/screens/LandingPage.tsx';
import client from '../../tina/__generated__/client';

const response = await client.queries.landing({ relativePath: 'landing.json' });
const { data } = response;
---

<BaseLayout
  title={data.landing.seo?.title || "Trusted Family Dental Clinic in Dindigul | Jamuna Family Dental Care"}
  description={data.landing.seo?.description || "Expert MDS specialist dental care in Dindigul — implants, root canal, braces, kids dentistry. 4.9★ rated. Call +91 7200 620 011."}
  canonical={data.landing.seo?.canonical || "https://jamunadental.com/dental"}
  noindex={data.landing.seo?.noindex}
  hideFooterMap
  hideNav
>
  <Screen data={data.landing} client:load />
</BaseLayout>
