---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQAccordionReact from '@/components/FAQAccordionReact';
import { loadHomepageContent } from '@/lib/load-homepage';

// Static-rendered React components (no `client:*` directive → no JS shipped)
import ServiceMarquee from '@/components/ServiceMarquee';
import AboutUsSection from '@/components/AboutUsSection';
import MilestonesSection from '@/components/MilestonesSection';
import MissionVisionSection from '@/components/MissionVisionSection';
import WhyChooseUsSection from '@/components/WhyChooseUsSection';
import PriceTellerSection from '@/components/PriceTellerSection';
import TeamSection from '@/components/TeamSection';
import InstagramReelsSection from '@/components/InstagramReelsSection';

// Hydrated React islands — only the genuinely interactive pieces
import HeroCarousel from '@/components/HeroCarousel';
import PhotoGalleryMarquee from '@/components/PhotoGalleryMarquee';
import TestimonialsSection from '@/components/TestimonialsSection';
import AppointmentBookingSection from '@/components/AppointmentBookingSection';
import SmileGallerySection from '@/components/SmileGallerySection';

// Static images
import { Image } from 'astro:assets';
// Hero avatar images — statically imported for Astro <Image> optimisation
import dentist1 from '@/assets/indian-dentist-male-1.jpg';
import dentist2 from '@/assets/indian-dentist-male-2.jpg';
import hygienist from '@/assets/indian-hygienist-female.jpg';

import {
  dentistSchema,
  organizationSchema,
  breadcrumbHome,
  homeFaqSchema,
} from '@/seo/schemas';
import { getImage } from 'astro:assets';

// Load content from TinaCMS
const homepageContent = await loadHomepageContent();

// Resolve all images in src/assets/uploads for Astro optimization
const allUploads = import.meta.glob('/src/assets/uploads/**/*.{png,jpg,jpeg,webp}', { eager: true });

async function resolveOptimizedImage(src: string, width: number, height: number, quality: number = 80) {
  if (!src) return null;
  
  // Tina stores paths like "/uploads/image.png" or "/uploads/image%20with%20space.png"
  // We need to decode it to match the actual file system key used by Vite glob
  const decodedSrc = decodeURIComponent(src);
  const assetPath = decodedSrc.startsWith('/uploads/') ? `/src/assets${decodedSrc}` : `/src/assets/uploads${decodedSrc.startsWith('/') ? '' : '/'}${decodedSrc}`;
  
  const imageModule: any = allUploads[assetPath];
  
  if (!imageModule) {
    console.warn(`Could not find image in src/assets/uploads: ${src} (looked for ${assetPath})`);
    return src; // Fallback to original URL
  }
  
  const optimized = await getImage({
    src: imageModule.default,
    width,
    height,
    format: 'webp',
    quality
  });
  
  return optimized.src;
}

// Optimize Hero Carousel images
const optimizedHeroImages = await Promise.all(
  (homepageContent?.hero_carousel?.images || []).map(async (img: any) => {
    const desktopSrc = await resolveOptimizedImage(img.src, 1000, 625, 75);
    const mobileSrc = await resolveOptimizedImage(img.src, 600, 450, 50);
    const smallMobileSrc = await resolveOptimizedImage(img.src, 360, 270, 45);
    return { ...img, src: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Optimize secondary sections images
const aboutDesktop = await resolveOptimizedImage(homepageContent?.about?.image, 1000, 1200, 80);
const aboutMobile = await resolveOptimizedImage(homepageContent?.about?.image, 600, 720, 60);
const aboutSmallMobile = await resolveOptimizedImage(homepageContent?.about?.image, 380, 456, 55);
const optimizedAbout = { image: aboutDesktop, mobileSrc: aboutMobile, smallMobileSrc: aboutSmallMobile };

const whyChooseDesktop = await resolveOptimizedImage(homepageContent?.why_choose?.image, 800, 600, 80);
const whyChooseMobile = await resolveOptimizedImage(homepageContent?.why_choose?.image, 480, 360, 60);
const whyChooseSmallMobile = await resolveOptimizedImage(homepageContent?.why_choose?.image, 300, 225, 55);
const optimizedWhyChoose = { image: whyChooseDesktop, mobileSrc: whyChooseMobile, smallMobileSrc: whyChooseSmallMobile };

const optimizedMilestonesImage = await resolveOptimizedImage(homepageContent?.milestones?.image, 1200, 800, 80);
const optimizedFaqImage = await resolveOptimizedImage(homepageContent?.faq?.image, 1000, 750, 80);

// Build services array — use optimized image
const services = await Promise.all((homepageContent?.services?.cards || []).map(async (card: any) => {
  const imageUrl = card.image || '/uploads/service-general-dentistry.png';
  const desktopSrc = await resolveOptimizedImage(imageUrl, 600, 450, 75);
  const mobileSrc = await resolveOptimizedImage(imageUrl, 450, 338, 50);
  const smallMobileSrc = await resolveOptimizedImage(imageUrl, 300, 225, 45);
  return {
    title: card.title,
    description: card.description,
    bullets: card.bullets?.map((b: any) => b.text) || [],
    imageUrl: desktopSrc,
    mobileSrc,
    smallMobileSrc,
    link: card.link,
  };
})) || [];

// Optimize Price Teller treatments images
const optimizedTreatments = await Promise.all((homepageContent?.price_teller?.treatments || []).map(async (t: any) => {
  const desktopSrc = await resolveOptimizedImage(t.image, 800, 600, 75);
  const mobileSrc = await resolveOptimizedImage(t.image, 600, 450, 50);
  const smallMobileSrc = await resolveOptimizedImage(t.image, 300, 225, 45);
  return { ...t, image: desktopSrc, mobileSrc, smallMobileSrc };
}));

// Optimize Clinic Gallery images (Limit to 6 on mobile)
const optimizedClinicImages = await Promise.all(
  (homepageContent?.clinic_gallery?.images || []).map(async (img: any) => {
    const desktopSrc = await resolveOptimizedImage(img.src, 500, 500, 75);
    const mobileSrc = await resolveOptimizedImage(img.src, 400, 400, 50);
    const smallMobileSrc = await resolveOptimizedImage(img.src, 300, 300, 45);
    return { ...img, src: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Optimize Photo Gallery images (Limit to 6 on mobile)
const optimizedPhotoImages = await Promise.all(
  (homepageContent?.photo_gallery?.images || []).map(async (img: any) => {
    const desktopSrc = await resolveOptimizedImage(img.src, 600, 600, 75);
    const mobileSrc = await resolveOptimizedImage(img.src, 400, 400, 60);
    const smallMobileSrc = await resolveOptimizedImage(img.src, 280, 280, 55);
    return { ...img, src: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Optimize Smile Gallery transformations
const optimizedTransformations = await Promise.all(
  (homepageContent?.smile_gallery?.transformations || []).map(async (item: any) => {
    const desktopSrc = await resolveOptimizedImage(item.image, 600, 600, 75);
    const mobileSrc = await resolveOptimizedImage(item.image, 450, 450, 60);
    const smallMobileSrc = await resolveOptimizedImage(item.image, 320, 320, 55);
    
    return { 
      ...item, 
      image: desktopSrc, 
      mobileSrc, 
      smallMobileSrc
    };
  })
);

// Optimize Team Member photos
const optimizedTeamMembers = await Promise.all(
  (homepageContent?.team?.members || []).map(async (member: any) => {
    const desktopSrc = await resolveOptimizedImage(member.photo, 400, 500, 75);
    const mobileSrc = await resolveOptimizedImage(member.photo, 280, 350, 60);
    const smallMobileSrc = await resolveOptimizedImage(member.photo, 200, 250, 55);
    return { ...member, photo: desktopSrc, mobileSrc, smallMobileSrc };
  })
);

// Build FAQs array from TinaCMS content
const faqs = homepageContent?.faq?.items?.map((item: any) => ({
  question: item.question,
  answer: item.answer,
})) || [];

// Use settings from TinaCMS or fallback
const title = homepageContent?.settings?.title || 'Best Dental Clinic in Dindigul | Jamuna Family Dental Care';
const description = homepageContent?.settings?.description || 'Jamuna Family Dental Care – Best dental clinic in Dindigul offering dental implants, root canal, teeth whitening, braces, smile design & pediatric dentistry. 4.9★ rated, 553+ Google reviews. Call +91 7200 620 011.';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jamunadental.com/"
  jsonLd={[dentistSchema, organizationSchema, breadcrumbHome, homeFaqSchema]}
>
  <style slot="head">
    /* Critical CSS for LCP improvement */
    #hero { min-height: 100vh; display: flex; align-items: center; }
    .hero-heading { font-size: 3rem; font-weight: 800; line-height: 1.1; margin-bottom: 0.75rem; }
    @media (min-width: 1024px) { .hero-heading { font-size: 4rem; } }
    .hero-subheading { color: #0080B5; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; font-size: 0.875rem; }
    .hero-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; font-weight: 700; }
    .header-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; }
  </style>
  
  {optimizedHeroImages[0] && (
    <link 
      rel="preload" 
      as="image" 
      href={optimizedHeroImages[0].src} 
      imagesrcset={`${optimizedHeroImages[0].smallMobileSrc} 380w, ${optimizedHeroImages[0].mobileSrc} 600w, ${optimizedHeroImages[0].src} 1000w`}
      imagesizes="(max-width: 480px) 380px, (max-width: 768px) 600px, 1000px"
      slot="head"
      fetchpriority="high"
    />
  )}

  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  {/* Static text + hydrated carousel island. Hero copy ships zero JS. */}
  <section id="hero" class="relative bg-background min-h-screen flex items-center pt-20">
    <div class="container mx-auto px-4 relative z-10 py-8">
      {/* On mobile: flex-col (order 1→2→3). On desktop: 2-col grid with carousel spanning both rows */}
      <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-x-16 gap-6 lg:items-center">

        {/* ① Heading — always first */}
        <div class="order-1 lg:col-start-1 lg:row-start-1 text-center lg:text-left pt-2">
          <h1 class="text-5xl lg:text-[4rem] xl:text-[4.5rem] font-extrabold leading-[1.1] mb-3 tracking-tight">
            <span class="text-gray-900 block">{homepageContent?.hero?.heading_part1}</span>
            <span class="text-primary block mt-1 xl:whitespace-nowrap">{homepageContent?.hero?.heading_part2}</span>
          </h1>
          <h2 class="text-[#0080B5] font-bold tracking-[0.15em] uppercase text-sm md:text-base">
            {homepageContent?.hero?.subheading}
          </h2>
        </div>

        {/* ② Carousel — between heading & content on mobile, right col spanning both rows on desktop */}
        <div class="order-2 lg:col-start-2 lg:row-start-1 lg:row-span-2 w-full">
          <HeroCarousel client:load images={optimizedHeroImages} />
        </div>

        {/* ③ Description, highlights, CTA, social proof — below carousel on mobile, left col row 2 on desktop */}
        <div class="order-3 lg:col-start-1 lg:row-start-2 flex flex-col gap-5 text-center lg:text-left pb-4">

          <p class="text-sm text-gray-600 leading-[1.6] max-w-2xl mx-auto lg:mx-0 font-medium">
            {homepageContent?.hero?.description}
          </p>

          <div class="flex items-start justify-center lg:justify-start py-3 px-2 sm:px-4 border border-gray-100 bg-white/60 backdrop-blur-md rounded-2xl shadow-[0_4px_15px_-4px_rgba(0,0,0,0.05)] w-fit mx-auto lg:mx-0 mt-2">
            {homepageContent?.hero?.highlights?.map((highlight: any, idx: number) => {
              const icons = [
                // Tooth
                <path d="M12 22C12 22 15 19 16.5 16C18 13 18.5 10 17.5 7.5C16.5 5 14 4 12 5C10 4 7.5 5 6.5 7.5C5.5 10 6 13 7.5 16C9 19 12 22 12 22Z" />,
                // Shield Check
                <g><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M9 12l2 2 4-4" /></g>,
                // People/Family
                <g><circle cx="9" cy="7" r="4"/><path d="M16 11l-2-2m-1.5-1.5L11 6"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="16" cy="11" r="3"/><path d="M13 21v-2a3 3 0 0 1 3-3h3a3 3 0 0 1 3 3v2"/></g>,
                // Hand holding Heart
                <g><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 18V8"/></g>
              ];
              return (
                <div class={`flex flex-col items-center px-4 ${idx !== homepageContent.hero.highlights.length - 1 ? 'border-r border-gray-300/60' : ''}`}>
                  <div class="w-12 h-12 rounded-full bg-white shadow-sm border border-blue-50 flex items-center justify-center mb-2">
                    <svg class="h-6 w-6 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      {icons[idx] || icons[0]}
                    </svg>
                  </div>
                  <span class="text-xs font-bold text-center text-primary leading-tight max-w-[80px]">
                    {highlight.text}
                  </span>
                </div>
              );
            })}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start mt-1">
            <a
              href={`tel:${homepageContent?.hero?.phone}`}
              onclick="window.gtag_report_phone_conversion?.()"
              class="inline-flex items-center justify-center bg-primary hover:bg-primary/90 text-white text-sm md:text-base px-6 py-3.5 rounded-full shadow-lg font-bold transition-all hover:-translate-y-1 hover:shadow-primary/30"
              aria-label={`Call Jamuna Dental at ${homepageContent?.hero?.phone}`}
            >
              <svg class="mr-2 h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.03 21c.76 0 .98-.66.98-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
              {homepageContent?.hero?.cta_text}
            </a>
            <a
              href={`https://wa.me/${homepageContent?.hero?.whatsapp_number?.replace(/\D/g, '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center bg-[#00A859] hover:bg-[#00924D] text-white text-sm md:text-base px-6 py-3.5 rounded-full shadow-lg font-bold transition-all hover:-translate-y-1 hover:shadow-[#00A859]/30"
              aria-label="Contact us on WhatsApp"
            >
              <svg class="mr-2 h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              {homepageContent?.hero?.whatsapp_text}
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* ─── Static sections (zero JS) ───────────────────────────────────── */}
  <ServiceMarquee services={homepageContent?.service_marquee?.services} />

  <div id="about">
    <AboutUsSection content={{ ...homepageContent?.about, ...optimizedAbout }} />
  </div>

  {/* New Clinic Gallery Marquee (runs right to left) */}
  <div class="hidden md:block">
    <PhotoGalleryMarquee client:visible content={{ ...homepageContent?.clinic_gallery, images: optimizedClinicImages }} />
  </div>
  <div class="md:hidden">
    <PhotoGalleryMarquee client:visible content={{ ...homepageContent?.clinic_gallery, images: optimizedClinicImages.slice(0, 6) }} />
  </div>

  <MilestonesSection client:visible content={{ ...homepageContent?.milestones, image: optimizedMilestonesImage }} />

  <MissionVisionSection client:visible content={homepageContent?.mission_vision} />

  {/* ─── Services grid (static HTML, just <a> + img) ─────────────────── */}
  <section id="services" class="py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 scroll-fade-up">
        <span class="inline-flex items-center px-3 py-1 mb-4 rounded-full text-xs font-semibold bg-primary text-primary-foreground">Our Services</span>
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-6">Complete Dental Care</h2>
        <p class="text-muted-foreground max-w-3xl mx-auto text-lg leading-relaxed">From routine treatments to advanced procedures, we provide a full range of dental services for all age groups in a clean and hygienic environment.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service, index) => (
          <a
            href={service.link}
            class={`scroll-fade-up delay-${(index % 4) * 100}`}
            aria-label={`View details about ${service.title}`}
          >
            <article class="group h-full overflow-hidden rounded-xl bg-card border border-border shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 hover:border-primary/50">
              <div class="relative aspect-[4/3] overflow-hidden">
                <img
                  src={service.imageUrl}
                  srcSet={`${service.smallMobileSrc} 320w, ${service.mobileSrc} 480w, ${service.imageUrl} 800w`}
                  sizes="(max-width: 480px) 320px, (max-width: 768px) 480px, 800px"
                  alt={service.title}
                  width={800}
                  height={600}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-foreground mb-3 group-hover:text-primary transition-colors">{service.title}</h3>
                <p class="text-muted-foreground text-base leading-relaxed mb-4">{service.description}</p>
                <ul class="space-y-1.5">
                  {service.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-sm text-foreground/80">
                      <svg class="h-4 w-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <PriceTellerSection 
    client:visible 
    content={{
      ...homepageContent?.price_teller,
      treatments: optimizedTreatments
    }} 
  />

  <SmileGallerySection 
    client:visible 
    content={{
      ...homepageContent?.smile_gallery,
      transformations: optimizedTransformations
    }} 
  />

  <TeamSection content={{ ...homepageContent?.team, members: optimizedTeamMembers }} />

  <WhyChooseUsSection content={{ ...homepageContent?.why_choose, ...optimizedWhyChoose }} />

  {/* Photo gallery slider — needs JS for the rAF-driven scroll */}
  <div class="hidden md:block">
    <PhotoGalleryMarquee client:visible content={{ ...homepageContent?.photo_gallery, images: optimizedPhotoImages }} hasGap={true} />
  </div>
  <div class="md:hidden">
    <PhotoGalleryMarquee client:visible content={{ ...homepageContent?.photo_gallery, images: optimizedPhotoImages.slice(0, 6) }} hasGap={true} />
  </div>

  {/* Static iframe-based reels */}
  <InstagramReelsSection client:visible content={homepageContent?.instagram_reels} />

  {/* JotForm widget injection — needs JS to mount the script */}
  <TestimonialsSection client:visible content={homepageContent?.testimonials} />

  <div id="appointment">
    {/* Form state lives here — hydrated island */}
    <AppointmentBookingSection client:visible content={homepageContent?.appointment} />
  </div>

  {/* ─── FAQ — static HTML accordion (no React, no JS) ───────────────── */}
  <section id="faq" class="py-20 bg-primary/5">
    <div class="container mx-auto px-4">
      <div class="mb-12 text-center lg:text-left scroll-fade-up">
        <span class="text-primary text-sm font-semibold tracking-wide mb-4 block">{homepageContent?.faq?.badge || 'FAQs'}</span>
        <h2 class="text-3xl md:text-4xl font-bold">
          <span class="text-primary">{homepageContent?.faq?.heading_part1 || 'Everything You Need To Know'}</span><br />
          <span class="text-foreground">{homepageContent?.faq?.heading_part2 || 'About Dental Care'}</span>
        </h2>
      </div>
      <div class="grid lg:grid-cols-5 gap-10 lg:gap-16 items-stretch">
        <div class="hidden lg:block lg:col-span-2 relative scroll-fade-right rounded-2xl overflow-hidden shadow-lg min-h-[500px]">
          <Image 
            src={optimizedFaqImage || '/uploads/service-general-dentistry.png'} 
            alt="Dental care professional treating a patient" 
            width={800}
            height={600}
            loading="lazy" 
            class="absolute inset-0 w-full h-full object-cover" 
          />
        </div>
        <div class="col-span-1 lg:col-span-3 scroll-fade-left flex flex-col justify-center">
          <FAQAccordionReact client:visible faqs={faqs.slice(0, 6)} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
