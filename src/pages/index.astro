---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import { loadHomepageContent } from '@/lib/load-homepage';

// Static-rendered React components (no `client:*` directive → no JS shipped)
import ServiceMarquee from '@/components/ServiceMarquee';
import AboutUsSection from '@/components/AboutUsSection';
import MilestonesSection from '@/components/MilestonesSection';
import MissionVisionSection from '@/components/MissionVisionSection';
import WhyChooseUsSection from '@/components/WhyChooseUsSection';
import InstagramReelsSection from '@/components/InstagramReelsSection';

// Hydrated React islands — only the genuinely interactive pieces
import HeroCarousel from '@/components/HeroCarousel';
import PhotoGalleryMarquee from '@/components/PhotoGalleryMarquee';
import TestimonialsSection from '@/components/TestimonialsSection';
import AppointmentBookingSection from '@/components/AppointmentBookingSection';

// Static images
import { Image } from 'astro:assets';
import dentalExam from '@/assets/service-general-dentistry.png';
import serviceRootCanal from '@/assets/service-root-canal.png';
import serviceImplants from '@/assets/service-implants.png';
import serviceSmileDesign from '@/assets/service-smile-design.png';
import orthodonticsAligners from '@/assets/orthodontics-aligners.jpg';
import pediatricDentistry from '@/assets/pediatric-dentistry.png';
import serviceToothExtraction from '@/assets/emergency-toothache.png';
import dentist1 from '@/assets/indian-dentist-male-1.jpg';
import dentist2 from '@/assets/indian-dentist-male-2.jpg';
import hygienist from '@/assets/indian-hygienist-female.jpg';

import {
  dentistSchema,
  organizationSchema,
  breadcrumbHome,
  homeFaqSchema,
} from '@/seo/schemas';

// Load content from TinaCMS
const homepageContent = await loadHomepageContent();

// Map service images to imported Image objects (handles both /assets/ and /uploads/ paths)
const serviceImageMap: Record<string, any> = {
  '/assets/service-general-dentistry.png': dentalExam,
  '/assets/service-root-canal.png': serviceRootCanal,
  '/assets/service-implants.png': serviceImplants,
  '/assets/service-smile-design.png': serviceSmileDesign,
  '/assets/orthodontics-aligners.jpg': orthodonticsAligners,
  '/assets/pediatric-dentistry.png': pediatricDentistry,
  '/assets/emergency-toothache.png': serviceToothExtraction,
  '/uploads/service-general-dentistry.png': dentalExam,
  '/uploads/service-root-canal.png': serviceRootCanal,
  '/uploads/service-implants.png': serviceImplants,
  '/uploads/service-smile-design.png': serviceSmileDesign,
  '/uploads/pediatric-dentistry.png': pediatricDentistry,
  '/uploads/emergency-toothache.png': serviceToothExtraction,
};

// Build services array from TinaCMS content
const services = homepageContent?.services?.cards?.map((card: any) => ({
  title: card.title,
  description: card.description,
  bullets: card.bullets?.map((b: any) => b.text) || [],
  image: serviceImageMap[card.image] || dentalExam,
  link: card.link,
})) || [];

// Build FAQs array from TinaCMS content
const faqs = homepageContent?.faq?.items?.map((item: any) => ({
  question: item.question,
  answer: item.answer,
})) || [];

// Use settings from TinaCMS or fallback
const title = homepageContent?.settings?.title || 'Best Dental Clinic in Dindigul | Jamuna Family Dental Care';
const description = homepageContent?.settings?.description || 'Jamuna Family Dental Care – Best dental clinic in Dindigul offering dental implants, root canal, teeth whitening, braces, smile design & pediatric dentistry. 4.9★ rated, 553+ Google reviews. Call +91 7200 620 011.';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jamunadental.com/"
  jsonLd={[dentistSchema, organizationSchema, breadcrumbHome, homeFaqSchema]}
>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  {/* Static text + hydrated carousel island. Hero copy ships zero JS. */}
  <section id="hero" class="relative bg-background min-h-screen flex items-center pt-20">
    <div class="container mx-auto px-4 relative z-10 py-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="flex flex-col gap-7 text-center lg:text-left order-1">

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
            <span class="text-foreground">{homepageContent?.hero?.heading_part1} </span>
            <span class="text-primary">{homepageContent?.hero?.heading_part2}</span>
            <span class="text-foreground"> {homepageContent?.hero?.heading_part3} </span>
            <span class="text-primary">{homepageContent?.hero?.heading_part4}</span>
          </h1>

          <p class="text-sm md:text-base text-foreground/80 leading-relaxed max-w-md mx-auto lg:mx-0">
            {homepageContent?.hero?.description}
          </p>

          <div class="grid grid-cols-2 gap-x-8 gap-y-3 justify-items-center lg:justify-items-start text-sm font-medium text-foreground/70">
            {homepageContent?.hero?.highlights?.map((highlight: any, idx: number) => {
              const icons = [
                "M12 3l1.9 5.8h6.1l-4.9 3.6 1.9 5.8L12 14.6l-4.9 3.6 1.9-5.8L4 8.8h6.1z",
                "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
                "M11 5.4l-1.4-1.4A4 4 0 1 0 5 9.6l7 7 7-7a4 4 0 0 0-5.6-5.6L11 5.4z",
                "M9 14l-2 7 5-3 5 3-2-7"
              ];
              const circleIcons = ["", "", "", "<circle cx=\"12\" cy=\"8\" r=\"6\"/>"];
              return (
                <span class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {circleIcons[idx] ? <path d={circleIcons[idx]} /> : null}
                    <path d={icons[idx]} />
                  </svg>
                  {highlight.text}
                </span>
              );
            })}
          </div>

          <div class="flex justify-center lg:justify-start">
            <a
              href={`tel:${homepageContent?.hero?.phone}`}
              onclick="window.gtag_report_phone_conversion?.()"
              class="inline-flex items-center justify-center bg-primary hover:bg-primary/90 text-primary-foreground text-lg px-10 py-5 rounded-full shadow-lg font-medium"
            >
              <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              {homepageContent?.hero?.cta_text}
            </a>
          </div>

          <div class="flex items-center gap-5 justify-center lg:justify-start">
            <div class="flex -space-x-3">
              <Image src={dentist1} alt="Dentist" width={44} height={44} class="w-11 h-11 rounded-full border-2 border-background object-cover shadow-md" />
              <Image src={dentist2} alt="Dentist" width={44} height={44} class="w-11 h-11 rounded-full border-2 border-background object-cover shadow-md" />
              <Image src={hygienist} alt="Hygienist" width={44} height={44} class="w-11 h-11 rounded-full border-2 border-background object-cover shadow-md" />
            </div>
            <div class="text-left">
              <div class="font-semibold text-foreground">{homepageContent?.hero?.social_proof?.review_count}</div>
              <div class="text-sm text-muted-foreground flex items-center gap-1">
                <span class="text-yellow-500">★★★★★</span> {homepageContent?.hero?.social_proof?.rating} Rating
              </div>
            </div>
          </div>

        </div>

        <div class="order-2 w-full">
          <HeroCarousel client:visible />
        </div>
      </div>
    </div>
  </section>

  {/* ─── Static sections (zero JS) ───────────────────────────────────── */}
  <ServiceMarquee />

  <div id="about">
    <AboutUsSection content={homepageContent?.about} />
  </div>

  <MilestonesSection client:visible />

  <MissionVisionSection client:visible />

  {/* ─── Services grid (static HTML, just <a> + img) ─────────────────── */}
  <section id="services" class="py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 scroll-fade-up">
        <span class="inline-flex items-center px-3 py-1 mb-4 rounded-full text-xs font-semibold bg-primary text-primary-foreground">Our Services</span>
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-6">Complete Dental Care</h2>
        <p class="text-muted-foreground max-w-3xl mx-auto text-lg leading-relaxed">From routine treatments to advanced procedures, we provide a full range of dental services for all age groups in a clean and hygienic environment.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, index) => (
          <a
            href={service.link}
            class={`scroll-fade-up delay-${(index % 3) * 100}`}
          >
            <article class="group h-full overflow-hidden rounded-xl bg-card border border-border shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 hover:border-primary/50">
              <div class="relative aspect-[4/3] overflow-hidden">
                <Image
                  src={service.image}
                  alt={service.title}
                  width={600}
                  height={450}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-foreground mb-3 group-hover:text-primary transition-colors">{service.title}</h3>
                <p class="text-muted-foreground text-base leading-relaxed mb-4">{service.description}</p>
                <ul class="space-y-1.5">
                  {service.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-sm text-foreground/80">
                      <svg class="h-4 w-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WhyChooseUsSection content={homepageContent?.why_choose} />

  {/* Photo gallery slider — needs JS for the rAF-driven scroll */}
  <PhotoGalleryMarquee client:visible />

  {/* Static iframe-based reels */}
  <InstagramReelsSection />

  {/* JotForm widget injection — needs JS to mount the script */}
  <TestimonialsSection client:visible />

  <div id="appointment">
    {/* Form state lives here — hydrated island */}
    <AppointmentBookingSection client:load />
  </div>

  {/* ─── FAQ — static HTML accordion (no React, no JS) ───────────────── */}
  <section id="faq" class="py-20 bg-primary/5">
    <div class="container mx-auto px-4">
      <div class="mb-12 text-center lg:text-left scroll-fade-up">
        <span class="text-primary text-sm font-semibold tracking-wide mb-4 block">{homepageContent?.faq?.badge || 'FAQs'}</span>
        <h2 class="text-3xl md:text-4xl font-bold">
          <span class="text-primary">{homepageContent?.faq?.heading_part1 || 'Everything You Need To Know'}</span><br />
          <span class="text-foreground">{homepageContent?.faq?.heading_part2 || 'About Dental Care'}</span>
        </h2>
      </div>
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        <div class="col-span-1 lg:col-span-3 scroll-fade-left">
          <FAQAccordion faqs={faqs} />
        </div>
        <div class="hidden lg:block lg:col-span-2 relative scroll-fade-right">
          <Image src={dentalExam} alt="Dental care" width={800} height={600} loading="lazy" class="w-full h-auto rounded-2xl object-cover shadow-lg" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
